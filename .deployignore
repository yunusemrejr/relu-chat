# .deployignore — Files/directories excluded from FTP deployment

# Credentials and sensitive files
ftp-info.txt
.env
.env.local
.env.example

# Git (never deploy .git)
.git
.gitignore

# Agent logs and backups
.agent-logs
_backups

# Deployment scripts
deploy.sh
deploy.sh.example
.deployignore

# Logs
*.log

# Data
data/*.db
data/*.sqlite
data/*.sqlite3

# IDE
.idea
.vscode

# Dependencies
node_modules
vendor
composer.json
composer.lock
package.json
package-lock.json

# OS
.DS_Store
Thumbs.db

# Documentation (deployed separately from README.md)
context.md
README.md
