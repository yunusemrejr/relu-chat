# ReLU.chat — Apache/LiteSpeed Configuration
# Last updated: 2026-04-17

# ============================================================
# 1. Disable directory listing (no file exposure)
# ============================================================
Options -Indexes

# ============================================================
# 2. Custom error pages
# ============================================================
ErrorDocument 404 /errors/404.html
ErrorDocument 403 /errors/403.html
ErrorDocument 500 /errors/500.html

# ============================================================
# 3. www → non-www redirect
# ============================================================
RewriteEngine On

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteCond %{HTTP_HOST} ^www\.relu\.chat$ [NC]
RewriteRule ^(.*)$ https://relu.chat/$1 [L,R=301]

# ============================================================
# 4. Protect sensitive files and directories
# ============================================================

# Block access to .git, .env, .agent-logs, data directory
<IfModule mod_rewrite.c>
    RewriteRule (^\.|^\.) - [F,L]
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block SQLite database files
<FilesMatch "\.(db|sqlite|sqlite3)$">
    Require all denied
</FilesMatch>

# Block .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>

# Block PHP files in data directory
<IfModule mod_rewrite.c>
    RewriteRule ^data/.*\.php$ - [F,L]
</IfModule>

# Block access to api directory listing (only PHP files should execute)
Options -Indexes

# ============================================================
# 5. Security headers (XSS, clickjacking, MIME sniffing, etc.)
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # CSP — allow self, jsdelivr CDN for KaTeX/Transformers, Cloudflare Insights, Google Fonts, HuggingFace for model downloads, and data: for images
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'"

    # Remove server signature
    Header always unset Server
    Header always unset X-Powered-By
</IfModule>

# ============================================================
# 6. MIME types and charset
# ============================================================
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
    AddType text/html .html
    AddType text/css .css
    AddType application/javascript .js
    AddType image/png .png
    AddType image/svg+xml .svg
    AddType image/x-icon .ico
    AddType application/json .json
</IfModule>

# ============================================================
# 7. Caching for static assets
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(png|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
    <FilesMatch "\.(html)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# ============================================================
# 8. Compression
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
