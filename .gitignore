# relu.chat - .gitignore
#
# Public open-source static site. Secrets, dev artifacts, private blog
# content, and operational noise are NEVER tracked in the public repo.

# --- Secrets & credentials (NEVER commit) ---
.env
.env.local
.env.example
.env.*
*.env
**/.env
**/.env.*
**/*-pass*
**/*-secret*
**/*-creds*
ftp-info.txt

# --- Agent / session artifacts (leaked to prod; stay local) ---
session-ses_*.md
session-*.md
opc_ua
.agent_memory/
.agent-logs/
.agent-imperative.json

# --- Dev folder (local-only ML training, backups, operational noise) ---
dev/
dev/**

# --- Local-only work (NEVER track; NEVER sync to prod) ---
_backups/
_backups/**
logs/
logs/**

# --- Deployment scripts and logs ---
deploy.sh
deploy.sh.example
.deployignore
.deployments/
deploy-*.log

# --- Documentation — local operational docs ---
docs/

# --- Generated / temp / caches ---
*.tmp
*.bak
*.swp
*~
.DS_Store
Thumbs.db
.idea/
.vscode/
*.sublime-*

# --- Dependencies / build outputs ---
node_modules/
vendor/
dist/
build/
.cache/
tmp/
temp/
*.zip
*.tar*
*.onnx
*.wasm
*.bin

# --- Logs ---
*.log

# --- Data (production databases; public site ships no DB) ---
data/*.db
data/*.sqlite
data/*.sqlite3

# --- Python cache ---
__pycache__/
*.pyc

# --- Blog system (PRIVATE — generated output + source; not part of public open-source repo) ---
blog/
content/
scripts/blog/

# --- Personal/user files on server ---
media/area51/

# --- Safety markers ---
.deployguard.local

# --- Never sync .git to prod ---
.git/
