# ReLU.chat — Deployment Configuration
#
# Copy this file to .env and fill in your actual credentials.
# Never commit .env to version control.
#
# For Namecheap shared hosting:
#   FTP_USER = Full FTP account format (e.g., relu@reult.chat)
#              For main cPanel user: just the username (e.g., eartctvi)
#   FTP_REMOTE = / (for addon domains, FTP root is already at /home/user/domain.com/)
#                For main domain: public_html
#   FTP_PORT = 21 for FTP/FTPS, 21098 for SFTP
#
# Protocol notes:
#   - SFTP (port 21098): Only works with main cPanel username/password
#   - FTPES (port 21): Works with all FTP accounts (recommended for additional FTP users)
#   - Plain FTP (port 21): Works but insecure, avoid if possible

FTP_HOST=your_server_ip
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_REMOTE=/
FTP_PORT=21