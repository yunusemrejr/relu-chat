# ReLU.chat — Deployment Configuration
#
# Copy this file to .env and fill in your actual credentials.
# Never commit .env to version control.
#
# For Namecheap shared hosting:
#   FTP_USER = cPanel username (e.g. eartctvi)
#   FTP_REMOTE = public_html (web root)
#   Or for addon domains: public_html/domain.com

FTP_HOST=199.188.200.140
FTP_USER=eartctvi
FTP_PASS=YOUR_C PANEL_PASSWORD_HERE
FTP_REMOTE=public_html
FTP_PORT=21
